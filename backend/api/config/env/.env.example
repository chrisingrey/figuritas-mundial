# Server
PORT=3000

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
# Optional comma-separated regular expressions for preview domains
CORS_ORIGIN_PATTERNS=

# Database
DATABASE_URL=

# Firebase Admin SDK
# Paste the complete serviceAccount.json contents as one JSON string in production.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Session JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Gmail SMTP settings for sending emails
GMAIL_USER=figuritas-mundialweb@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Frontend app base URL used for album invitation links
FRONTEND_BASE_URL=http://localhost:5173

# Frontend route that handles email validation links
EMAIL_VALIDATION_BASE_URL=http://localhost:5173/verify-email

# Frontend route that handles password reset links
PASSWORD_RESET_BASE_URL=http://localhost:5173/reset-password

# Optional dedicated secret for password reset tokens (falls back to JWT_SECRET)
RESET_PASSWORD_TOKEN_SECRET=
